{
  "id": "facebook",
  "label": "Facebook",
  "description": "Starter profile for Facebook. Update the selectors to match the UI you want to hide.",
  "rules": [
    {
      "type": "setAddressBar",
      "selector": "location",
      "value": "/dashboard"
    },
    {
      "type": "setTitle",
      "selector": "title",
      "value": "Web Dashboard"
    },
    {
      "type": "remove",
      "selector": "header[role='banner']"
    },
    {
      "type": "remove",
      "selector": "nav[aria-label='Facebook']"
    }
  ]
}