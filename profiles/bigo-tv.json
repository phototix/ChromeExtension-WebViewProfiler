{
  "id": "bigo-tv",
  "label": "Bigo.tv",
  "description": "Cleans up the Bigo.tv layout by hiding header/overlay components, pinning the content wrapper to the top, and hiding everything after the room container without breaking reactive DOM updates.",
  "rules": [
    {
      "type": "style",
      "selector": "header.PageHead-Component",
      "declarations": {
        "display": {
          "value": "none",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": "div.FixTool-Component",
      "declarations": {
        "display": {
          "value": "none",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": "div.privacy-popup",
      "declarations": {
        "display": {
          "value": "none",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": ".room-video",
      "declarations": {
        "display": {
          "value": "none",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": ".room",
      "declarations": {
        "margin": {
          "value": "0px",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": ".room-container__right",
      "declarations": {
        "min-height": {
          "value": "600px",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": ".def-container .page-wrapper",
      "declarations": {
        "padding-top": {
          "value": "0px",
          "important": true
        }
      }
    },
    {
      "type": "hideAfter",
      "selector": "div.room-container"
    },
    {
      "type": "style",
      "selector": "div.chat-item.type-init",
      "declarations": {
        "display": {
          "value": "none",
          "important": true
        }
      }
    }
  ]
}