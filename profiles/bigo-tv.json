{
  "id": "bigo-tv",
  "label": "Bigo.tv",
  "description": "Cleans up the Bigo.tv layout by removing the header and overlay components, pinning the content wrapper to the top, and removing everything after the room container.",
  "rules": [
    {
      "type": "remove",
      "selector": "header.PageHead-Component"
    },
    {
      "type": "remove",
      "selector": "div.FixTool-Component"
    },
    {
      "type": "remove",
      "selector": "div.privacy-popup"
    },
    {
      "type": "remove",
      "selector": ".room-video"
    },
    {
      "type": "style",
      "selector": ".room",
      "declarations": {
        "margin": {
          "value": "0px",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": ".room-container__right",
      "declarations": {
        "min-height": {
          "value": "500px",
          "important": true
        }
      }
    },
    {
      "type": "style",
      "selector": ".def-container .page-wrapper",
      "declarations": {
        "padding-top": {
          "value": "0px",
          "important": true
        }
      }
    },
    {
      "type": "removeAfter",
      "selector": "div.room-container"
    },
    {
      "type": "remove",
      "selector": "div.chat-item.type-init"
    }
  ]
}